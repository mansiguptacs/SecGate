# SecGate local env (gitignored). Do not commit real secrets.
BACKEND=akash
AKASH_API_KEY=
# If Console API key is missing/403, leases auto-fall back to dry-run so the
# Control Tower spend widget still updates. Force dry-run with:
# AKASH_DRY_RUN=1
# AKASH_API_TIMEOUT_MS=8000

# Nexla — demo default is the local MCP shim (Control Tower "Nexla" badge).
# Fastest path to a *real* Nexla ToolSet when Studio file-upload is limited:
#   1) npm run start:phase2
#   2) npm run tunnel:budget   → public HTTPS URL
#   3) In Studio: REST/API source → GET {url}/budget?team=platform-eng
#   4) ToolSet from Nexset → export MCP → set NEXLA_USE_SHIM=0 below
# Details: docs/nexla/option2-api-source.md
NEXLA_USE_SHIM=1
NEXLA_MCP_URL=http://127.0.0.1:3300/mcp
NEXLA_SERVICE_KEY=nxl_sk_secgate_demo_shim
NEXLA_BUDGET_TOOL=get_team_budget
NEXLA_TEAM=platform-eng
NEXLA_SHIM_PORT=3300
# Real Nexla later (set from Studio MCP export — do not commit the full URL):
# NEXLA_USE_SHIM=0
# NEXLA_MCP_URL=https://api-genai.nexla.io/mcp/service_key/<server_key>
# NEXLA_SERVICE_KEY=<GenAI service key from Nexla UI / booth — not your password>
# NEXLA_BUDGET_TOOL=nexset_read_team_budget   # or get_team_budget — use tools/list name
