# SecGate local env (gitignored). Do not commit real secrets.
BACKEND=akash
AKASH_API_KEY=

# Nexla — demo default is the local MCP shim (Control Tower "Nexla" badge).
# At the booth, set NEXLA_USE_SHIM=0 and paste the real ToolSet URL + service key.
NEXLA_USE_SHIM=1
NEXLA_MCP_URL=http://127.0.0.1:3300/mcp
NEXLA_SERVICE_KEY=nxl_sk_secgate_demo_shim
NEXLA_BUDGET_TOOL=get_team_budget
NEXLA_TEAM=platform-eng
NEXLA_SHIM_PORT=3300
# Real Nexla later:
# NEXLA_USE_SHIM=0
# NEXLA_MCP_URL=https://api-genai.nexla.io/mcp/service_key/<server_key>
# NEXLA_SERVICE_KEY=nxl_sk_....
